    ws.sheet_view.zoomScale = 85
    ws.freeze_panes = "A3"
    add_title(ws, title, end_col=10)
    ws["A2"] = "Populate yellow response cells in 1_Input_Request. This tab auto-pulls those inputs."
    ws["A2"].font = small_font
    ws.merge_cells("A2:F2")
    add_back_to_input(ws, 2, 8)
    if widths:
        set_widths(ws, widths)
 
