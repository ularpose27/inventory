        "Gifts & Hospitality – Amount",
        "Gifts & Hospitality – Count",
        "ABC Activity – Count",
        "Panel Firm Engagements – Count",
        "Breaches / Issues – Count",
    ]
    for idx, metric in enumerate(metrics):
        r = hdr + 1 + idx
        ws.cell(r, 1, metric)
        style(ws.cell(r, 1), fill=fill_label, font=font_body, align=align_left)
        # source input table columns: A metric B/C/D months E total F notes
        for out_col, in_col in zip([2,3,4,5,6], [2,3,4,5,6]):
            src = f"{get_column_letter(in_col)}{m['COI_MONTHLY_START'] + idx}"
            cell = ws.cell(r, out_col, f"='INPUT_TEAM_LEADER'!{src}")
            fmt = None
            if out_col in (2,3,4,5) and idx == 0:
                fmt = '$#,##0;[Red]($#,##0);-'
            elif out_col == 5 and idx > 0:
                fmt = '#,##0;[Red](#,##0);-'
            style(cell, fill=fill_note if out_col != 5 else fill_metric, font=font_body if out_col != 5 else font_metric, align=align_center if out_col != 6 else align_left, numfmt=fmt)
        set_row(ws, r, 24)
    row = hdr + 7
