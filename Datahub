def apply_number_formats(wb, block):
    ws = wb["INPUT_TEAM_LEADER"]
    # currency / percentage formats
    for key in ["HC_ACTUAL_LOSSES", "FCC_FRAUD_LOSS"]:
        ws[block[key]].number_format = '$#,##0'
    for key in ["CS_SCU_PASS", "CS_FLOD_PASS"]:
