def html_table(headers, rows, align_right=True, totals_row=False):
    t = ["<table>", "<thead>", "<tr>"]
    for i, h in enumerate(headers):
        align = "right" if i > 0 and align_right else "left"
        t.append(f'<th style="text-align:{align};">{html_escape(h)}</th>')
    t.append("</tr>")
    t.append("</thead>")
    t.append("<tbody>")
    
    for r_idx, row in enumerate(rows):
        is_total = totals_row and r_idx == len(rows) - 1
        tr_class = ' class="total-row"' if is_total else ''
        t.append(f"<tr{tr_class}>")
        for i, cell in enumerate(row):
            align = "right" if i > 0 and align_right else "left"
            t.append(f'<td style="text-align:{align};">{html_escape(cell)}</td>')
        t.append("</tr>")
        
    t.append("</tbody>")
    t.append("</table>")
    return "\n".join(t)

