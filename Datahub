# VALIDATION ENGINE
# ==============================================================================

def validate_financials(fin):
    tolerance = 1.0 # Due to rounding and float arithmetic
    for i in range(len(fin["Years"])):
        # IS validation
        rev = fin["IS"]["Revenue"][i]
        cogs = fin["IS"]["COGS"][i]
        gp = fin["IS"]["GrossProfit"][i]
        opex = fin["IS"]["Opex"][i]
        ebitda = fin["IS"]["EBITDA"][i]
        da = fin["IS"]["DA"][i]
        ebit = fin["IS"]["EBIT"][i]
        interest = fin["IS"]["Interest"][i]
        ebt = fin["IS"]["EBT"][i]
        tax = fin["IS"]["Tax"][i]
        ni = fin["IS"]["NetIncome"][i]
        
        assert abs(gp - (rev - cogs)) < tolerance, f"GP Validation Failed Year {i}"
        assert abs(ebitda - (gp - opex)) < tolerance, f"EBITDA Validation Failed Year {i}"
        assert abs(ebit - (ebitda - da)) < tolerance, f"EBIT Validation Failed Year {i}"
        assert abs(ebt - (ebit - interest)) < tolerance, f"EBT Validation Failed Year {i}"
        assert abs(ni - (ebt - tax)) < tolerance, f"NI Validation Failed Year {i}"
        
        # BS validation
        cash = fin["BS"]["Cash"][i]
        ar = fin["BS"]["AR"][i]
        inv = fin["BS"]["Inventory"][i]
        tca = fin["BS"]["TotalCA"][i]
        ppne = fin["BS"]["PPNE"][i]
        tnca = fin["BS"]["TotalNCA"][i]
        ta = fin["BS"]["TotalAssets"][i]
        ap = fin["BS"]["AP"][i]
        std = fin["BS"]["ST_Debt"][i]
        tcl = fin["BS"]["TotalCL"][i]
        ltd = fin["BS"]["LT_Debt"][i]
        tncl = fin["BS"]["TotalNCL"][i]
        tl = fin["BS"]["TotalLiabilities"][i]
        eq = fin["BS"]["Equity"][i]
        tle = fin["BS"]["TotalLiabilitiesEquity"][i]

        assert abs(tca - (cash + ar + inv)) < tolerance, f"TCA Validation Failed Year {i}"
        assert abs(tnca - ppne) < tolerance, f"TNCA Validation Failed Year {i}"
        assert abs(ta - (tca + tnca)) < tolerance, f"TA Validation Failed Year {i}"
        assert abs(tcl - (ap + std)) < tolerance, f"TCL Validation Failed Year {i}"
        assert abs(tncl - ltd) < tolerance, f"TNCL Validation Failed Year {i}"
        assert abs(tl - (tcl + tncl)) < tolerance, f"TL Validation Failed Year {i}"
        assert abs(tle - (tl + eq)) < tolerance, f"TLE Validation Failed Year {i}"
        assert abs(ta - tle) < tolerance, f"Balance Sheet does not balance Year {i}. Diff: {ta - tle}"

        # CF validation
        cf_cash = fin["CF"]["EndingCash"][i]
        assert abs(cash - cf_cash) < tolerance, f"Cash in BS does not match CF Ending Cash Year {i}"

