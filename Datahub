        "selling_expenses": [0.074, 0.075, 0.076, 0.075, 0.071, 0.070, 0.069, 0.068],
        "logistics_and_fulfillment_expenses": [0.052, 0.055, 0.061, 0.064, 0.057, 0.055, 0.053, 0.052],
        "technology_and_platform_expenses": [0.014, 0.015, 0.017, 0.018, 0.016, 0.016, 0.015, 0.015],
        "general_and_administrative_expenses": [0.055, 0.053, 0.050, 0.048, 0.043, 0.043, 0.042, 0.041],
        "bad_debt_expense": [0.006, 0.007, 0.010, 0.010, 0.010, 0.009, 0.008, 0.008],
    }
    dso = [48, 50, 56, 58, 55, 52, 50, 48]
    dio = [115, 118, 132, 145, 136, 128, 120, 115]
    dpo = [62, 60, 64, 67, 65, 67, 68, 70]
    capex = [42.0, 55.0, 145.0, 115.0, 70.0, 65.0, 55.0, 50.0]
    tech_investments = [8.0, 10.0, 16.0, 20.0, 18.0, 18.0, 16.0, 14.0]
    total_debt = [230.0, 290.0, 510.0, 690.0, 640.0, 590.0, 535.0, 485.0]
    leases_total = [42.0, 48.0, 55.0, 60.0, 35.0, 32.0, 30.0, 28.0]
    dividends = [8.0, 10.0, 5.0, 0.0, 0.0, 0.0, 8.0, 15.0]

    initial = {
        "cash": 150.0,
        "accounts_receivable": 1020.0 * 48 / 365,
        "inventory": 1020.0 * (1 - 0.31) * 110 / 365,
        "accounts_payable": 1020.0 * (1 - 0.31) * 62 / 365,
        "other_working_capital": 1020.0 * 0.035 + 20.0 * 0.35 - 1020.0 * 0.014 - 1020.0 * 0.008,
        "debt": 190.0,
        "ppe": 310.0,
        "intangibles": 24.0,
        "retained_earnings": 160.0,
    }

    income = {}
    balance = {}
    cash_flow = {}
    debt_schedule = {}
    retained = initial["retained_earnings"]
    ppe = initial["ppe"]
    intangibles = initial["intangibles"]
    beginning_cash = initial["cash"]
    previous_ar = initial["accounts_receivable"]
    previous_inventory = initial["inventory"]
    previous_ap = initial["accounts_payable"]
    previous_owc = initial["other_working_capital"]
    previous_debt = initial["debt"]

    for i, year in enumerate(labels):
        rev = revenue[i]
        cogs = round(rev * (1 - gross_margin[i]), 1)
        gross_profit = round(rev - cogs, 1)
        selling = round(rev * expense_ratios["selling_expenses"][i], 1)
        logistics = round(rev * expense_ratios["logistics_and_fulfillment_expenses"][i], 1)
        tech = round(rev * expense_ratios["technology_and_platform_expenses"][i], 1)
        ga = round(rev * expense_ratios["general_and_administrative_expenses"][i], 1)
        bad = round(rev * expense_ratios["bad_debt_expense"][i], 1)
        ebitda = round(gross_profit - selling - logistics - tech - ga - bad, 1)
        ebit = round(ebitda - da[i], 1)
        ebt = round(ebit - interest[i] + fx[i] + other[i], 1)
        tax = round(max(0.0, ebt * 0.30), 1)
        net_income = round(ebt - tax, 1)

        ar = round(rev * dso[i] / 365, 1)
        inventory = round(cogs * dio[i] / 365, 1)
        ap = round(cogs * dpo[i] / 365, 1)
        prepaid = round(rev * 0.014, 1)
        other_current = round(rev * 0.008, 1)
        accrued = round(rev * 0.035, 1)
        taxes_payable = round(tax * 0.35, 1)
        operating_other_wc = round(accrued + taxes_payable - prepaid - other_current, 1)

        change_ar = round(ar - previous_ar, 1)
        change_inventory = round(inventory - previous_inventory, 1)
        change_ap = round(ap - previous_ap, 1)
        change_other_wc = round(operating_other_wc - previous_owc, 1)
        net_cfo = round(net_income + da[i] - change_ar - change_inventory + change_ap + change_other_wc, 1)
        net_cfi = round(-(capex[i] + tech_investments[i]), 1)
        debt_delta = round(total_debt[i] - previous_debt, 1)
        new_debt = max(debt_delta, 0.0)
        debt_repayment = max(-debt_delta, 0.0)
        lease_payments = 10.0
        net_cff = round(new_debt - debt_repayment - lease_payments - dividends[i], 1)
        net_change_cash = round(net_cfo + net_cfi + net_cff, 1)
        ending_cash = round(beginning_cash + net_change_cash, 1)

        ppe = round(ppe + capex[i] - da[i] * 0.72, 1)
        rou_assets = round(leases_total[i] * 0.85, 1)
        intangibles = round(intangibles + tech_investments[i] - da[i] * 0.16, 1)
        deferred_tax_assets = round(8.0 + i * 0.7, 1)

        total_current_assets = round(ending_cash + ar + inventory + prepaid + other_current, 1)
        total_noncurrent_assets = round(ppe + rou_assets + intangibles + deferred_tax_assets, 1)
        total_assets = round(total_current_assets + total_noncurrent_assets, 1)

        short_debt_ratio = 0.33 if i < 5 else 0.27
        short_debt = round(total_debt[i] * short_debt_ratio, 1)
        long_debt = round(total_debt[i] - short_debt, 1)
        current_lease = round(leases_total[i] * 0.32, 1)
        long_lease = round(leases_total[i] - current_lease, 1)
        deferred_tax_liabilities = round(5.0 + i * 0.6, 1)
        other_liabilities = round(18.0 + i * 1.1, 1)
        total_current_liabilities = round(ap + short_debt + current_lease + accrued + taxes_payable, 1)
        total_noncurrent_liabilities = round(long_debt + long_lease + deferred_tax_liabilities + other_liabilities, 1)
        total_liabilities = round(total_current_liabilities + total_noncurrent_liabilities, 1)

        share_capital = 245.0
        retained = round(retained + net_income - dividends[i], 1)
        other_reserves = round(total_assets - total_liabilities - share_capital - retained, 1)
        total_equity = round(share_capital + retained + other_reserves, 1)
        total_liabilities_and_equity = round(total_liabilities + total_equity, 1)

        income[year] = {
            "revenue": rev,
            "cost_of_goods_sold": cogs,
            "gross_profit": gross_profit,
            "selling_expenses": selling,
            "logistics_and_fulfillment_expenses": logistics,
            "technology_and_platform_expenses": tech,
            "general_and_administrative_expenses": ga,
            "bad_debt_expense": bad,
            "ebitda": ebitda,
            "depreciation_and_amortization": da[i],
            "ebit": ebit,
            "interest_expense": interest[i],
            "fx_gain_loss": fx[i],
            "other_income_expense": other[i],
            "earnings_before_tax": ebt,
            "income_tax": tax,
            "net_income": net_income,
        }

        balance[year] = {
            "cash_and_equivalents": ending_cash,
            "accounts_receivable": ar,
            "inventory": inventory,
            "prepaid_expenses": prepaid,
            "other_current_assets": other_current,
            "total_current_assets": total_current_assets,
            "property_plant_and_equipment": ppe,
            "right_of_use_assets": rou_assets,
            "intangible_assets": intangibles,
            "deferred_tax_assets": deferred_tax_assets,
            "total_non_current_assets": total_noncurrent_assets,
            "total_assets": total_assets,
            "accounts_payable": ap,
            "short_term_debt": short_debt,
            "current_lease_liabilities": current_lease,
            "accrued_expenses": accrued,
            "taxes_payable": taxes_payable,
            "total_current_liabilities": total_current_liabilities,
            "long_term_debt": long_debt,
            "long_term_lease_liabilities": long_lease,
            "deferred_tax_liabilities": deferred_tax_liabilities,
            "other_liabilities": other_liabilities,
            "total_non_current_liabilities": total_noncurrent_liabilities,
            "total_liabilities": total_liabilities,
            "share_capital": share_capital,
            "retained_earnings": retained,
            "other_reserves": other_reserves,
            "total_equity": total_equity,
            "total_liabilities_and_equity": total_liabilities_and_equity,
        }

        cash_flow[year] = {
            "net_income": net_income,
            "depreciation_and_amortization": da[i],
            "change_in_accounts_receivable": -change_ar,
            "change_in_inventory": -change_inventory,
            "change_in_accounts_payable": change_ap,
            "change_in_other_working_capital": change_other_wc,
            "net_cash_from_operating_activities": net_cfo,
            "capital_expenditures": -capex[i],
            "technology_investments": -tech_investments[i],
            "net_cash_from_investing_activities": net_cfi,
            "new_debt_issued": new_debt,
            "debt_repayment": -debt_repayment,
            "lease_payments": -lease_payments,
            "dividends": -dividends[i],
            "net_cash_from_financing_activities": net_cff,
            "net_change_in_cash": net_change_cash,
            "beginning_cash": beginning_cash,
            "ending_cash": ending_cash,
        }

        debt_schedule[year] = {
            "revolver_and_working_capital_lines": round(total_debt[i] * 0.34, 1),
            "expansion_bridge_and_term_debt": round(total_debt[i] * 0.42, 1),
            "equipment_loans": round(total_debt[i] * 0.14, 1),
            "supplier_financing": round(total_debt[i] * 0.10, 1),
            "total_debt": total_debt[i],
            "lease_liabilities": leases_total[i],
            "total_debt_including_leases": round(total_debt[i] + leases_total[i], 1),
        }

        beginning_cash = ending_cash
        previous_ar = ar
        previous_inventory = inventory
        previous_ap = ap
        previous_owc = operating_other_wc
        previous_debt = total_debt[i]

    return {
        "years": labels,
        "historical_years": labels[:5],
        "forecast_years": labels[5:],
        "income": income,
        "balance": balance,
        "cash_flow": cash_flow,
        "debt_schedule": debt_schedule,
        "drivers": {
