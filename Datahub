def write_html_file(html_content, output_path):
    path = Path(output_path)
    path.write_text(html_content, encoding="utf-8")
    return path


def build_data():
    company = generate_company_profile()
    financials = generate_historical_financials()
    forecast_financials = generate_forecast_financials(financials)
    ratios = calculate_ratios(financials)
    products = generate_product_data(financials)
    channels = generate_channel_data(financials)
    customers = generate_customer_schedule(financials)
    suppliers = generate_supplier_schedule(financials)
    wc = generate_working_capital_schedules(financials)
    receivables = generate_receivables_schedule(financials, customers)
    inventory = generate_inventory_schedule(financials, products)
    payables = generate_payables_schedule(financials, suppliers)
    debt_rows = generate_debt_schedule(financials)
    collateral = generate_collateral_schedule(financials)
    borrowing_base = generate_borrowing_base(financials, wc)
    scenarios = generate_scenarios(financials)
    sensitivities = generate_sensitivities(financials)

    data = {
        "company": company,
        "financials": financials,
        "forecast_financials": forecast_financials,
        "ratios": ratios,
        "products": products,
        "channels": channels,
        "customers": customers,
        "suppliers": suppliers,
        "working_capital": wc,
        "receivables": receivables,
        "inventory": inventory,
