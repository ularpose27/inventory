def generate_borrowing_base(financials, wc):
    ar = financials["balance"]["FY2025"]["accounts_receivable"]
    inventory = financials["balance"]["FY2025"]["inventory"]

    ineligible_ar = round(wc["ar_aging"]["Over 90 days"] + ar * 0.035, 1)
    eligible_ar = round(ar - ineligible_ar, 1)
    obsolete = round(wc["inventory_aging"]["Over 365 days"], 1)
    slow_moving = round(wc["inventory_aging"]["181–365 days"] * 0.55, 1)
    other_ineligible_inventory = round(inventory * 0.06, 1)
    eligible_inventory = round(inventory - obsolete - slow_moving - other_ineligible_inventory, 1)

    ar_advance = round(eligible_ar * 0.80, 1)
    inventory_advance = round(eligible_inventory * 0.50, 1)
    reserves = round((ar_advance + inventory_advance) * 0.07, 1)
    support = round(ar_advance + inventory_advance - reserves, 1)

    return {
        "gross_accounts_receivable": ar,
        "less_ineligible_receivables": -ineligible_ar,
        "eligible_accounts_receivable": eligible_ar,
        "ar_advance_rate": 0.80,
        "ar_availability": ar_advance,
        "gross_inventory": inventory,
        "less_obsolete_inventory": -obsolete,
        "less_slow_moving_inventory": -slow_moving,
        "less_other_ineligible_inventory": -other_ineligible_inventory,
        "eligible_inventory": eligible_inventory,
        "inventory_advance_rate": 0.50,
        "inventory_availability": inventory_advance,
        "reserves": -reserves,
        "estimated_borrowing_base_support": support,
        "existing_utilization": 218.0,
        "requested_revolver_size": 325.0,
        "seasonal_peak_need": 302.0,
    }


def generate_scenarios(financials):
    base_years = financials["forecast_years"]
    scenarios = {}

    assumptions = {
        "Base case": {
            "revenue_multiplier": [1.00, 1.00, 1.00],
            "ebitda_multiplier": [1.00, 1.00, 1.00],
            "cash_shift": [0, 0, 0],
        },
        "Downside case": {
            "revenue_multiplier": [0.94, 0.92, 0.91],
            "ebitda_multiplier": [0.78, 0.74, 0.73],
            "cash_shift": [-45, -62, -74],
        },
        "Upside case": {
            "revenue_multiplier": [1.04, 1.07, 1.09],
            "ebitda_multiplier": [1.14, 1.19, 1.23],
            "cash_shift": [28, 54, 83],
        },
    }

    for scenario, ass in assumptions.items():
        rows = []
        for i, year in enumerate(base_years):
            inc = financials["income"][year]
            bs = financials["balance"][year]
            cf = financials["cash_flow"][year]

            revenue = round(inc["revenue"] * ass["revenue_multiplier"][i], 1)
            ebitda = round(inc["ebitda"] * ass["ebitda_multiplier"][i], 1)
            net_income = round(max(-25.0, inc["net_income"] * ass["ebitda_multiplier"][i] - (inc["revenue"] - revenue) * 0.03), 1)
            operating_cf = round(cf["net_cash_from_operating_activities"] * ass["ebitda_multiplier"][i] + ass["cash_shift"][i] * 0.25, 1)
            free_cf = round(operating_cf + cf["net_cash_from_investing_activities"], 1)
            cash = round(bs["cash_and_equivalents"] + ass["cash_shift"][i], 1)
            net_debt = round(financials["debt_schedule"][year]["total_debt_including_leases"] - cash, 1)
            debt_service = inc["interest_expense"] + max(0.0, -cf["debt_repayment"]) + max(0.0, -cf["lease_payments"])

            rows.append(
                {
                    "year": year,
                    "revenue": revenue,
                    "ebitda": ebitda,
                    "net_income": net_income,
                    "operating_cash_flow": operating_cf,
                    "free_cash_flow": free_cf,
                    "cash_balance": cash,
                    "net_debt": net_debt,
                    "dscr": ebitda / debt_service,
                    "interest_coverage": ebitda / inc["interest_expense"],
                }
            )

        scenarios[scenario] = rows

    return scenarios


def generate_sensitivities(financials):
    fy = financials["income"]["FY2026"]
    base_revenue = fy["revenue"]
    base_ebitda_margin = fy["ebitda"] / fy["revenue"]
    tables = {}

    revenue_growths = [-0.05, 0.00, 0.05, 0.10]
    ebitda_margins = [
        base_ebitda_margin - 0.015,
        base_ebitda_margin,
        base_ebitda_margin + 0.015,
        base_ebitda_margin + 0.030,
    ]

    tables["Revenue growth vs EBITDA"] = [
        [format_pct(g), *[format_mxn(base_revenue * (1 + g) * m) for m in ebitda_margins]]
        for g in revenue_growths
    ]

    tables["Gross margin vs EBITDA"] = [
        [format_pct(gm), format_mxn(base_revenue * (gm - 0.195)), format_mxn(base_revenue * (gm - 0.205)), format_mxn(base_revenue * (gm - 0.215))]
        for gm in [0.275, 0.290, 0.305, 0.320]
    ]

    tables["Inventory days vs cash tied up"] = [
        [format_days(days), format_mxn(financials["income"]["FY2026"]["cost_of_goods_sold"] * days / 365)]
        for days in [105, 120, 135, 150, 165]
    ]

    tables["DSO vs cash tied up"] = [
        [format_days(days), format_mxn(base_revenue * days / 365)]
        for days in [40, 50, 60, 70, 80]
    ]

