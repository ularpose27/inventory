def svg_bar_chart(title, labels, values, width=720, height=280, suffix=""):
    if not values:
        return ""
    max_value = max(max(values), 1)
    left = 58
    bottom = 44
    top = 38
    plot_w = width - left - 25
    plot_h = height - top - bottom
    bar_gap = 10
    bar_w = max(10, (plot_w - bar_gap * (len(values) - 1)) / len(values))
    parts = [f"<svg class='chart' viewBox='0 0 {width} {height}' role='img' aria-label='{html_escape(title)}'>"]
    parts.append(f"<text x='{width/2}' y='22' text-anchor='middle' class='chart-title'>{html_escape(title)}</text>")
    parts.append(f"<line x1='{left}' y1='{top + plot_h}' x2='{width-15}' y2='{top + plot_h}' class='axis'/>")
    parts.append(f"<line x1='{left}' y1='{top}' x2='{left}' y2='{top + plot_h}' class='axis'/>")
    for idx, (label, value) in enumerate(zip(labels, values)):
        x = left + idx * (bar_w + bar_gap)
        h = 0 if max_value == 0 else (value / max_value) * (plot_h - 8)
        y = top + plot_h - h
        parts.append(f"<rect x='{x:.1f}' y='{y:.1f}' width='{bar_w:.1f}' height='{h:.1f}' class='bar'/>")
        parts.append(f"<text x='{x + bar_w/2:.1f}' y='{top + plot_h + 18}' text-anchor='middle' class='chart-label'>{html_escape(label)}</text>")
        parts.append(f"<text x='{x + bar_w/2:.1f}' y='{max(y - 5, 35):.1f}' text-anchor='middle' class='chart-value'>{format_mxn(value)}{html_escape(suffix)}</text>")
    parts.append("</svg>")
    return "".join(parts)


def svg_line_chart(title, labels, values, width=720, height=280, suffix=""):
    if not values:
        return ""
    min_v = min(values)
    max_v = max(values)
    if is_close(min_v, max_v, 0.0001):
        min_v -= 1
        max_v += 1
    left = 58
    bottom = 44
    top = 38
    plot_w = width - left - 25
    plot_h = height - top - bottom
    points = []
    for i, value in enumerate(values):
        x = left + (plot_w * i / max(len(values) - 1, 1))
        y = top + plot_h - ((value - min_v) / (max_v - min_v) * (plot_h - 8))
        points.append((x, y))
    polyline = " ".join(f"{x:.1f},{y:.1f}" for x, y in points)
    parts = [f"<svg class='chart' viewBox='0 0 {width} {height}' role='img' aria-label='{html_escape(title)}'>"]
    parts.append(f"<text x='{width/2}' y='22' text-anchor='middle' class='chart-title'>{html_escape(title)}</text>")
    parts.append(f"<line x1='{left}' y1='{top + plot_h}' x2='{width-15}' y2='{top + plot_h}' class='axis'/>")
    parts.append(f"<line x1='{left}' y1='{top}' x2='{left}' y2='{top + plot_h}' class='axis'/>")
    parts.append(f"<polyline points='{polyline}' class='line-series'/>")
    for (x, y), label, value in zip(points, labels, values):
        parts.append(f"<circle cx='{x:.1f}' cy='{y:.1f}' r='4.5' class='line-point'/>")
        parts.append(f"<text x='{x:.1f}' y='{top + plot_h + 18}' text-anchor='middle' class='chart-label'>{html_escape(label)}</text>")
        parts.append(f"<text x='{x:.1f}' y='{max(y - 8, 34):.1f}' text-anchor='middle' class='chart-value'>{format_mxn(value)}{html_escape(suffix)}</text>")
    parts.append("</svg>")
    return "".join(parts)


def svg_stacked_bar_chart(title, labels, series, width=720, height=310):
    keys = list(series.keys())
    totals = [sum(series[k][i] for k in keys) for i in range(len(labels))]
    max_value = max(max(totals), 1)
    left = 58
    bottom = 58
    top = 40
    plot_w = width - left - 28
    plot_h = height - top - bottom
    bar_gap = 11
    bar_w = max(10, (plot_w - bar_gap * (len(labels) - 1)) / len(labels))
    classes = ["stack-a", "stack-b", "stack-c", "stack-d", "stack-e"]
    parts = [f"<svg class='chart' viewBox='0 0 {width} {height}' role='img' aria-label='{html_escape(title)}'>"]
    parts.append(f"<text x='{width/2}' y='22' text-anchor='middle' class='chart-title'>{html_escape(title)}</text>")
    parts.append(f"<line x1='{left}' y1='{top + plot_h}' x2='{width-20}' y2='{top + plot_h}' class='axis'/>")
    for idx, label in enumerate(labels):
        x = left + idx * (bar_w + bar_gap)
        y_cursor = top + plot_h
        for j, key in enumerate(keys):
            value = series[key][idx]
            h = value / max_value * (plot_h - 8)
            y_cursor -= h
            parts.append(f"<rect x='{x:.1f}' y='{y_cursor:.1f}' width='{bar_w:.1f}' height='{h:.1f}' class='{classes[j % len(classes)]}'/>")
        parts.append(f"<text x='{x + bar_w/2:.1f}' y='{top + plot_h + 18}' text-anchor='middle' class='chart-label'>{html_escape(label)}</text>")
    legend_x = left
    legend_y = height - 23
    for j, key in enumerate(keys):
        x = legend_x + j * 130
        parts.append(f"<rect x='{x}' y='{legend_y-10}' width='12' height='12' class='{classes[j % len(classes)]}'/>")
        parts.append(f"<text x='{x+18}' y='{legend_y}' class='legend'>{html_escape(key)}</text>")
    parts.append("</svg>")
    return "".join(parts)


