def style_cell(cell, fill=None, font=None, align=None, border=all_border, numfmt=None):
    if fill:
        cell.fill = fill
    if font:
        cell.font = font
    if align:
        cell.alignment = align
    if border:
        cell.border = border
    if numfmt:
        cell.number_format = numfmt
 
 
def merge_write(ws, cell_range, value, fill=None, font=None, align=None, border=all_border, numfmt=None):
    ws.merge_cells(cell_range)
    cell = ws[cell_range.split(":")[0]]
    cell.value = value
    style_cell(cell, fill=fill, font=font, align=align, border=border, numfmt=numfmt)
    return cell
 
 
def set_row(ws, row, height):
    ws.row_dimensions[row].height = height
 
 
def input_row(ws, row, label, resp_cell, note="", response_width="E:F", response_type="text"):
    merge_write(ws, f"B{row}:D{row}", label, fill=label_fill, font=body_font, align=left)
    merge_write(ws, f"E{row}:F{row}", "", fill=input_fill, font=input_font, align=left)
    merge_write(ws, f"G{row}:H{row}", note, fill=note_fill, font=small_font, align=left)
    set_row(ws, row, 23)
    return f"E{row}"
 
 
def write_headers_row(ws, row, headers, fills=None, widths=None):
    for idx, header in enumerate(headers, start=1):
        c = ws.cell(row=row, column=idx, value=header)
        style_cell(c, fill=(fills[idx-1] if fills else section_fill), font=white_font, align=center)
        if widths:
            ws.column_dimensions[get_column_letter(idx)].width = widths[idx-1]
 
 
