def add_title(ws, title, end_col=8):
    ws.merge_cells(start_row=1, start_column=1, end_row=1, end_column=end_col)
    c = ws.cell(1, 1, title)
    c.fill = title_fill
    c.font = title_font
    c.alignment = left
    ws.row_dimensions[1].height = 24
 
def style_cell(cell, fill=None, font=None, alignment=None, border=None, num_format=None):
    if fill:
        cell.fill = fill
    if font:
        cell.font = font
    if alignment:
        cell.alignment = alignment
    if border:
        cell.border = border
    if num_format:
        cell.number_format = num_format
 
def set_widths(ws, widths):
    for col, width in widths.items():
        ws.column_dimensions[get_column_letter(col)].width = width
 
def pull_formula(input_id):
    # INDEX/MATCH for compatibility
    return f'=IFERROR(INDEX(\'1_Input_Request\'!$G:$G,MATCH("{input_id}",\'1_Input_Request\'!$C:$C,0)),"")'
 
def pull_text_with_label(label, input_id):
    return f'="{label}: "&IFERROR(INDEX(\'1_Input_Request\'!$G:$G,MATCH("{input_id}",\'1_Input_Request\'!$C:$C,0)),"")'
 
def add_back_to_input(ws, row, col=1):
    c = ws.cell(row, col, "Go to Input tab")
    c.hyperlink = "#'1_Input_Request'!A1"
    c.style = "Hyperlink"
    c.font = Font(name="Calibri", size=10, underline="single", color="0563C1")
 
def add_table_header(ws, row, headers, start_col=1):
    for idx, h in enumerate(headers, start=start_col):
        cell = ws.cell(row, idx, h)
        style_cell(cell, fill=section_fill, font=section_font, alignment=center, border=all_border)
    ws.row_dimensions[row].height = 22
 
def add_label_value_table(ws, start_row, title, rows, start_col=1):
    ws.merge_cells(start_row=start_row, start_column=start_col, end_row=start_row, end_column=start_col+1)
    c = ws.cell(start_row, start_col, title)
    style_cell(c, fill=section_fill, font=section_font, alignment=left, border=all_border)
    r = start_row + 1
    for label, formula, fmt in rows:
        lc = ws.cell(r, start_col, label)
        vc = ws.cell(r, start_col+1)
        lc.fill = subheader_fill
        lc.font = subheader_font
        lc.alignment = left
        lc.border = all_border
        vc.value = formula
        vc.fill = metric_fill
        vc.font = formula_font
        vc.alignment = center
        vc.border = all_border
        if fmt:
            vc.number_format = fmt
        r += 1
    return r
 
def add_notes_box(ws, start_row, title, ids, start_col=5, width=4):
    ws.merge_cells(start_row=start_row, start_column=start_col, end_row=start_row, end_column=start_col+width-1)
    c = ws.cell(start_row, start_col, title)
    style_cell(c, fill=section_fill, font=section_font, alignment=left, border=all_border)
    row = start_row + 1
    for item_title, input_id in ids:
        ws.merge_cells(start_row=row, start_column=start_col, end_row=row, end_column=start_col+width-1)
        cc = ws.cell(row, start_col)
        cc.value = pull_text_with_label(item_title, input_id)
        style_cell(cc, fill=note_fill, font=formula_font, alignment=left, border=all_border)
        row += 1
    return row
 
