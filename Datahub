def add_issue_table(ws, title, start_row, headers, row_keys):
    ws.merge_cells(start_row=start_row, start_column=1, end_row=start_row, end_column=len(headers))
    c = ws.cell(start_row, 1, title)
    style_cell(c, fill=section_fill, font=section_font, alignment=left, border=all_border)
    add_table_header(ws, start_row + 1, headers, 1)
    r = start_row + 2
    for keyset in row_keys:
        for col_idx, input_id in enumerate(keyset, start=1):
            cell = ws.cell(r, col_idx)
            cell.value = pull_formula(input_id)
            style_cell(cell, fill=metric_fill, font=formula_font, alignment=left if col_idx not in (3,5) else center, border=all_border)
            if "DATE" in input_id or "CLOSE_DATE" in input_id or "ORIG_DATE" in input_id or "NEW_DATE" in input_id:
                cell.number_format = 'DD-MMM-YYYY'
        r += 1
    return r + 1
 
