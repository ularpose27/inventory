def calculate_ratios(financials):
    ratios = {}
    previous_revenue = None

    for year in financials["years"]:
        inc = financials["income"][year]
        bs = financials["balance"][year]
        cf = financials["cash_flow"][year]
        ds = financials["debt_schedule"][year]

        revenue_growth = None if previous_revenue is None else inc["revenue"] / previous_revenue - 1
        total_debt_including_leases = ds["total_debt_including_leases"]
        net_debt = total_debt_including_leases - bs["cash_and_equivalents"]
        debt_service = inc["interest_expense"] + max(0.0, -cf["debt_repayment"]) + max(0.0, -cf["lease_payments"])
        fixed_charges = debt_service + max(0.0, -cf["dividends"])

        ratios[year] = {
            "revenue_growth": revenue_growth,
            "gross_margin": inc["gross_profit"] / inc["revenue"],
            "ebitda_margin": inc["ebitda"] / inc["revenue"],
            "ebit_margin": inc["ebit"] / inc["revenue"],
            "net_margin": inc["net_income"] / inc["revenue"],
            "return_on_assets": inc["net_income"] / bs["total_assets"],
            "return_on_equity": inc["net_income"] / bs["total_equity"],
            "current_ratio": bs["total_current_assets"] / bs["total_current_liabilities"],
            "quick_ratio": (bs["cash_and_equivalents"] + bs["accounts_receivable"]) / bs["total_current_liabilities"],
            "cash_ratio": bs["cash_and_equivalents"] / bs["total_current_liabilities"],
            "inventory_turnover": inc["cost_of_goods_sold"] / bs["inventory"],
            "days_inventory_outstanding": bs["inventory"] / inc["cost_of_goods_sold"] * 365,
            "days_sales_outstanding": bs["accounts_receivable"] / inc["revenue"] * 365,
            "days_payable_outstanding": bs["accounts_payable"] / inc["cost_of_goods_sold"] * 365,
            "cash_conversion_cycle": (
                bs["inventory"] / inc["cost_of_goods_sold"] * 365
                + bs["accounts_receivable"] / inc["revenue"] * 365
                - bs["accounts_payable"] / inc["cost_of_goods_sold"] * 365
            ),
            "asset_turnover": inc["revenue"] / bs["total_assets"],
            "total_debt": total_debt_including_leases,
            "net_debt": net_debt,
            "net_debt_to_ebitda": net_debt / inc["ebitda"],
            "debt_to_equity": total_debt_including_leases / bs["total_equity"],
            "debt_to_total_capitalization": total_debt_including_leases / (total_debt_including_leases + bs["total_equity"]),
            "interest_coverage": inc["ebitda"] / inc["interest_expense"],
            "dscr": inc["ebitda"] / debt_service if debt_service else None,
            "fixed_charge_coverage": inc["ebitda"] / fixed_charges if fixed_charges else None,
            "operating_cash_flow_conversion": cf["net_cash_from_operating_activities"] / inc["ebitda"],
            "free_cash_flow_conversion": (
                cf["net_cash_from_operating_activities"] + cf["net_cash_from_investing_activities"]
            )
            / inc["ebitda"],
        }

        previous_revenue = inc["revenue"]

    return ratios


