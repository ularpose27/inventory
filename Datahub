def svg_bar_chart(title, labels, values, color="#1e3a8a", width=600, height=300):
    if not values: return ""
    max_val = max(values) * 1.1 if max(values) > 0 else 100
    svg = [f'<div class="chart-container"><h4>{html_escape(title)}</h4>']
    svg.append(f'<svg width="{width}" height="{height}" viewBox="0 0 {width} {height}" xmlns="http://www.w3.org/2000/svg">')
    
    margin_bottom = 40
    margin_left = 60
    margin_top = 20
    margin_right = 20
    
    chart_w = width - margin_left - margin_right
    chart_h = height - margin_top - margin_bottom
    
    bar_w = chart_w / len(values) * 0.7
    spacing = chart_w / len(values)
    
    # Axes
    svg.append(f'<line x1="{margin_left}" y1="{height - margin_bottom}" x2="{width - margin_right}" y2="{height - margin_bottom}" stroke="#ccc" />')
    svg.append(f'<line x1="{margin_left}" y1="{margin_top}" x2="{margin_left}" y2="{height - margin_bottom}" stroke="#ccc" />')
    
    # Y-axis labels
    for i in range(5):
        y_val = max_val * (4 - i) / 4
        y_pos = margin_top + chart_h * (i / 4)
        svg.append(f'<text x="{margin_left - 10}" y="{y_pos + 5}" font-size="10" text-anchor="end" fill="#666">{int(y_val)}</text>')
        svg.append(f'<line x1="{margin_left}" y1="{y_pos}" x2="{width - margin_right}" y2="{y_pos}" stroke="#eee" />')

    # Bars and X-axis labels
    for i, (lbl, val) in enumerate(zip(labels, values)):
        x_pos = margin_left + i * spacing + (spacing - bar_w) / 2
        bar_h = (val / max_val) * chart_h if max_val > 0 else 0
        y_pos = height - margin_bottom - bar_h
        
        svg.append(f'<rect x="{x_pos}" y="{y_pos}" width="{bar_w}" height="{bar_h}" fill="{color}" rx="2" />')
        svg.append(f'<text x="{x_pos + bar_w/2}" y="{height - margin_bottom + 20}" font-size="10" text-anchor="middle" fill="#333">{html_escape(lbl)}</text>')
        svg.append(f'<text x="{x_pos + bar_w/2}" y="{y_pos - 5}" font-size="10" text-anchor="middle" fill="#333">{int(val)}</text>')

    svg.append('</svg></div>')
    return "\n".join(svg)

def svg_line_chart(title, labels, values, color="#10b981", width=600, height=300):
    if not values: return ""
    max_val = max(values) * 1.1 if max(values) > 0 else 100
    min_val = min(values) * 0.9 if min(values) < 0 else 0
    y_range = max_val - min_val if max_val != min_val else 100

    svg = [f'<div class="chart-container"><h4>{html_escape(title)}</h4>']
    svg.append(f'<svg width="{width}" height="{height}" viewBox="0 0 {width} {height}" xmlns="http://www.w3.org/2000/svg">')
    
    margin_bottom = 40
    margin_left = 60
    margin_top = 20
    margin_right = 20
    
    chart_w = width - margin_left - margin_right
    chart_h = height - margin_top - margin_bottom
    spacing = chart_w / max(1, len(values) - 1)
    
    # Grid
    for i in range(5):
        y_val = max_val - y_range * (i / 4)
        y_pos = margin_top + chart_h * (i / 4)
        svg.append(f'<text x="{margin_left - 10}" y="{y_pos + 5}" font-size="10" text-anchor="end" fill="#666">{y_val:.1f}</text>')
        svg.append(f'<line x1="{margin_left}" y1="{y_pos}" x2="{width - margin_right}" y2="{y_pos}" stroke="#eee" />')

    # Line
    points = []
    for i, val in enumerate(values):
        x_pos = margin_left + i * spacing
        y_pos = height - margin_bottom - ((val - min_val) / y_range) * chart_h
        points.append(f"{x_pos},{y_pos}")
    
    svg.append(f'<polyline points="{" ".join(points)}" fill="none" stroke="{color}" stroke-width="3" />')
    
    # Points and labels
    for i, (lbl, val) in enumerate(zip(labels, values)):
        x_pos = margin_left + i * spacing
        y_pos = height - margin_bottom - ((val - min_val) / y_range) * chart_h
        svg.append(f'<circle cx="{x_pos}" cy="{y_pos}" r="4" fill="{color}" />')
        svg.append(f'<text x="{x_pos}" y="{height - margin_bottom + 20}" font-size="10" text-anchor="middle" fill="#333">{html_escape(lbl)}</text>')

    svg.append('</svg></div>')
    return "\n".join(svg)

def svg_stacked_bar_chart(title, labels, series_dict, colors, width=600, height=300):
    # series_dict: {"Series1": [v1, v2..], "Series2": [v1, v2..]}
    svg = [f'<div class="chart-container"><h4>{html_escape(title)}</h4>']
    svg.append(f'<svg width="{width}" height="{height}" viewBox="0 0 {width} {height}" xmlns="http://www.w3.org/2000/svg">')
    
    margin_bottom = 60
    margin_left = 60
    margin_top = 20
    margin_right = 80
    
    chart_w = width - margin_left - margin_right
    chart_h = height - margin_top - margin_bottom
    
    num_pts = len(labels)
    bar_w = chart_w / num_pts * 0.6
    spacing = chart_w / num_pts
    
    # Max sum
    max_sum = 0
    for i in range(num_pts):
        s = sum(series_dict[k][i] for k in series_dict.keys())
        if s > max_sum: max_sum = s
    max_sum = max_sum * 1.1 if max_sum > 0 else 100

    # Grid
    for i in range(5):
        y_val = max_sum * (4 - i) / 4
        y_pos = margin_top + chart_h * (i / 4)
        svg.append(f'<text x="{margin_left - 10}" y="{y_pos + 5}" font-size="10" text-anchor="end" fill="#666">{int(y_val)}</text>')
        svg.append(f'<line x1="{margin_left}" y1="{y_pos}" x2="{width - margin_right}" y2="{y_pos}" stroke="#eee" />')

    # Bars
    for i, lbl in enumerate(labels):
        x_pos = margin_left + i * spacing + (spacing - bar_w) / 2
        svg.append(f'<text x="{x_pos + bar_w/2}" y="{height - margin_bottom + 20}" font-size="10" text-anchor="middle" fill="#333">{html_escape(lbl)}</text>')
        
        current_y = height - margin_bottom
        for j, (s_name, s_vals) in enumerate(series_dict.items()):
            val = s_vals[i]
            bar_h = (val / max_sum) * chart_h if max_sum > 0 else 0
            current_y -= bar_h
            svg.append(f'<rect x="{x_pos}" y="{current_y}" width="{bar_w}" height="{bar_h}" fill="{colors[j % len(colors)]}" />')

    # Legend
    legend_y = margin_top
    for j, s_name in enumerate(series_dict.keys()):
        svg.append(f'<rect x="{width - margin_right + 10}" y="{legend_y}" width="10" height="10" fill="{colors[j % len(colors)]}" />')
        svg.append(f'<text x="{width - margin_right + 25}" y="{legend_y + 9}" font-size="10" fill="#333">{html_escape(s_name)}</text>')
        legend_y += 20

    svg.append('</svg></div>')
    return "\n".join(svg)

