def create_lookups_sheet(wb):
    ws = wb.create_sheet("LOOKUPS")
    ws.sheet_state = "hidden"
    headers = ["Quarter", "Month 1", "Month 2", "Month 3"]
    for i, h in enumerate(headers, start=1):
        c = ws.cell(row=1, column=i, value=h)
        style_cell(c, fill=section_fill, font=white_font, align=center)
    data = [
        ["Q1", "Jan", "Feb", "Mar"],
        ["Q2", "Apr", "May", "Jun"],
        ["Q3", "Jul", "Aug", "Sep"],
        ["Q4", "Oct", "Nov", "Dec"],
    ]
    for r, row in enumerate(data, start=2):
        for c_idx, val in enumerate(row, start=1):
            c = ws.cell(row=r, column=c_idx, value=val)
            style_cell(c, fill=note_fill, font=body_font, align=center)
    ws["F1"] = "Years"
    for y, row in enumerate(range(2024, 2036), start=2):
        ws[f"F{y}"] = row
    return ws
 
 
def add_validations(ws):
    qdv = DataValidation(type="list", formula1='"Q1,Q2,Q3,Q4"', allow_blank=False)
    ydv = DataValidation(type="list", formula1='=LOOKUPS!$F$2:$F$13', allow_blank=False)
    ws.add_data_validation(qdv)
    ws.add_data_validation(ydv)
    qdv.add(ws["B1"])
    ydv.add(ws["D1"])
 
 
def make_kpi_table(ws, start_row, title, items):
    merge_write(ws, f"A{start_row}:H{start_row}", title, fill=section_fill, font=section_font, align=left)
    set_row(ws, start_row, 21)
    row = start_row + 1
    for label, key, note, typ in items:
        merge_write(ws, f"B{row}:D{row}", label, fill=label_fill, font=body_font, align=left)
        merge_write(ws, f"E{row}:F{row}", "", fill=input_fill, font=input_font, align=left)
        merge_write(ws, f"G{row}:H{row}", note, fill=note_fill, font=small_font, align=left)
        set_row(ws, row, 22 if typ != "Long text" else 32)
        row += 1
    return row
 
 
def make_detail_input_table(ws, start_row, title, headers, rows_count, table_widths=None):
    merge_write(ws, f"A{start_row}:H{start_row}", title, fill=section_fill, font=section_font, align=left)
    header_row = start_row + 1
    cols = list(range(1, len(headers)+1))
    widths = table_widths or [10] * len(headers)
    for col_num, (header, width) in enumerate(zip(headers, widths), start=1):
        c = ws.cell(row=header_row, column=col_num, value=header)
        style_cell(c, fill=sub_fill, font=sub_font, align=center)
        ws.column_dimensions[get_column_letter(col_num)].width = max(ws.column_dimensions[get_column_letter(col_num)].width or 0, width)
    for r in range(header_row + 1, header_row + 1 + rows_count):
        for c_idx in cols:
            c = ws.cell(row=r, column=c_idx, value="")
            style_cell(c, fill=input_fill if c_idx > 0 else note_fill, font=input_font, align=top_left)
        set_row(ws, r, 28)
    return header_row + 1, header_row + rows_count
 
 
