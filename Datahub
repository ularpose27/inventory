def html_table(headers, rows, caption=None, classes="", numeric_columns=None):
    numeric_columns = set(numeric_columns or [])
    caption_html = f"<caption>{html_escape(caption)}</caption>" if caption else ""
    head = "".join(f"<th>{html_escape(h)}</th>" for h in headers)
    body_rows = []
    for row in rows:
        cells = []
        for i, cell in enumerate(row):
            cls = " class='num'" if i in numeric_columns else ""
            if isinstance(cell, str) and cell.startswith("<"):
                cells.append(f"<td{cls}>{cell}</td>")
            else:
                cells.append(f"<td{cls}>{html_escape(cell)}</td>")
        body_rows.append("<tr>" + "".join(cells) + "</tr>")
    return f"""
    <table class="data-table {html_escape(classes)}">
        {caption_html}
        <thead><tr>{head}</tr></thead>
        <tbody>{''.join(body_rows)}</tbody>
    </table>
    """


