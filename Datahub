def validate_financials(data):
    financials = data["financials"]
    ratios = data["ratios"]

    for year in financials["years"]:
        inc = financials["income"][year]
        bs = financials["balance"][year]
        cf = financials["cash_flow"][year]
        ds = financials["debt_schedule"][year]

        checks = [
            (inc["gross_profit"], inc["revenue"] - inc["cost_of_goods_sold"], f"gross profit reconciliation {year}"),
            (
                inc["ebitda"],
                inc["gross_profit"]
                - inc["selling_expenses"]
                - inc["logistics_and_fulfillment_expenses"]
                - inc["technology_and_platform_expenses"]
                - inc["general_and_administrative_expenses"]
                - inc["bad_debt_expense"],
                f"EBITDA reconciliation {year}",
            ),
            (inc["ebit"], inc["ebitda"] - inc["depreciation_and_amortization"], f"EBIT reconciliation {year}"),
            (inc["earnings_before_tax"], inc["ebit"] - inc["interest_expense"] + inc["fx_gain_loss"] + inc["other_income_expense"], f"EBT reconciliation {year}"),
            (inc["net_income"], inc["earnings_before_tax"] - inc["income_tax"], f"net income reconciliation {year}"),
            (
                bs["total_current_assets"],
                bs["cash_and_equivalents"] + bs["accounts_receivable"] + bs["inventory"] + bs["prepaid_expenses"] + bs["other_current_assets"],
                f"current assets sum {year}",
            ),
            (
                bs["total_non_current_assets"],
                bs["property_plant_and_equipment"] + bs["right_of_use_assets"] + bs["intangible_assets"] + bs["deferred_tax_assets"],
                f"non-current assets sum {year}",
            ),
            (
                bs["total_current_liabilities"],
                bs["accounts_payable"] + bs["short_term_debt"] + bs["current_lease_liabilities"] + bs["accrued_expenses"] + bs["taxes_payable"],
                f"current liabilities sum {year}",
            ),
            (
                bs["total_non_current_liabilities"],
                bs["long_term_debt"] + bs["long_term_lease_liabilities"] + bs["deferred_tax_liabilities"] + bs["other_liabilities"],
                f"non-current liabilities sum {year}",
            ),
            (bs["total_assets"], bs["total_liabilities_and_equity"], f"balance sheet equality {year}"),
            (cf["ending_cash"], bs["cash_and_equivalents"], f"cash flow ending cash to balance sheet {year}"),
            (ds["total_debt"], bs["short_term_debt"] + bs["long_term_debt"], f"debt schedule to balance sheet debt {year}"),
            (ds["lease_liabilities"], bs["current_lease_liabilities"] + bs["long_term_lease_liabilities"], f"lease liabilities to balance sheet {year}"),
            (
                cf["net_cash_from_operating_activities"],
                cf["net_income"]
                + cf["depreciation_and_amortization"]
                + cf["change_in_accounts_receivable"]
                + cf["change_in_inventory"]
                + cf["change_in_accounts_payable"]
                + cf["change_in_other_working_capital"],
                f"operating cash flow derivation {year}",
            ),
            (
                cf["net_cash_from_operating_activities"] + cf["net_cash_from_investing_activities"],
                cf["net_cash_from_operating_activities"] + cf["capital_expenditures"] + cf["technology_investments"],
                f"free cash flow derivation {year}",
            ),
        ]

        for left, right, message in checks:
            if not is_close(left, right):
                raise ValueError(f"Validation failed: {message}. Left={left}, right={right}")

        expected_net_debt = ds["total_debt_including_leases"] - bs["cash_and_equivalents"]
        if not is_close(ratios[year]["net_debt"], expected_net_debt):
            raise ValueError(f"Validation failed: net debt {year}")

        if not is_close(ratios[year]["current_ratio"], bs["total_current_assets"] / bs["total_current_liabilities"], 0.01):
            raise ValueError(f"Validation failed: current ratio {year}")

        if not is_close(ratios[year]["quick_ratio"], (bs["cash_and_equivalents"] + bs["accounts_receivable"]) / bs["total_current_liabilities"], 0.01):
            raise ValueError(f"Validation failed: quick ratio {year}")

        if not is_close(ratios[year]["inventory_turnover"], inc["cost_of_goods_sold"] / bs["inventory"], 0.01):
            raise ValueError(f"Validation failed: inventory turnover {year}")

        if not is_close(ratios[year]["days_sales_outstanding"], bs["accounts_receivable"] / inc["revenue"] * 365, 0.05):
            raise ValueError(f"Validation failed: DSO {year}")

        if not is_close(ratios[year]["days_inventory_outstanding"], bs["inventory"] / inc["cost_of_goods_sold"] * 365, 0.05):
            raise ValueError(f"Validation failed: DIO {year}")

        if not is_close(ratios[year]["days_payable_outstanding"], bs["accounts_payable"] / inc["cost_of_goods_sold"] * 365, 0.05):
            raise ValueError(f"Validation failed: DPO {year}")

        ccc = ratios[year]["days_sales_outstanding"] + ratios[year]["days_inventory_outstanding"] - ratios[year]["days_payable_outstanding"]
        if not is_close(ratios[year]["cash_conversion_cycle"], ccc, 0.05):
            raise ValueError(f"Validation failed: cash conversion cycle {year}")

        debt_service = inc["interest_expense"] + max(0.0, -cf["debt_repayment"]) + max(0.0, -cf["lease_payments"])
        if debt_service and not is_close(ratios[year]["dscr"], inc["ebitda"] / debt_service, 0.01):
            raise ValueError(f"Validation failed: DSCR {year}")

        if not is_close(ratios[year]["interest_coverage"], inc["ebitda"] / inc["interest_expense"], 0.01):
            raise ValueError(f"Validation failed: interest coverage {year}")


def statement_table(title, data_dict, years, rows):
    table_rows = []
    for label, key in rows:
        table_rows.append([label] + [format_mxn(data_dict[y][key]) for y in years])
    return html_table([title] + years, table_rows, numeric_columns=range(1, len(years) + 1))


def ratio_table(title, ratios, years, rows):
    table_rows = []
    for label, key, formatter in rows:
        table_rows.append([label] + [formatter(ratios[y][key]) for y in years])
    return html_table([title] + years, table_rows, numeric_columns=range(1, len(years) + 1))


