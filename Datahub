align_center = Alignment(horizontal="center", vertical="center", wrap_text=True)
align_left = Alignment(horizontal="left", vertical="center", wrap_text=True)
align_top_left = Alignment(horizontal="left", vertical="top", wrap_text=True)
 
def style(cell, fill=None, font=None, align=None, numfmt=None):
    if fill is not None:
        cell.fill = fill
    if font is not None:
        cell.font = font
    if align is not None:
        cell.alignment = align
    cell.border = border
    if numfmt:
        cell.number_format = numfmt
 
def merge_write(ws, rng, value, fill=None, font=None, align=None, numfmt=None):
    ws.merge_cells(rng)
    cell = ws[rng.split(":")[0]]
    cell.value = value
    style(cell, fill=fill, font=font, align=align, numfmt=numfmt)
    return cell
 
def set_widths(ws, widths):
    for col_idx, width in widths.items():
        ws.column_dimensions[get_column_letter(col_idx)].width = width
 
def set_row(ws, row, height):
    ws.row_dimensions[row].height = height
 
def ref(addr):
    return f"='INPUT_TEAM_LEADER'!{addr}"
 
def dynamic_title(sheet_title):
    return f'=CONCAT("{sheet_title} | ",INPUT_TEAM_LEADER!$B$1," ",INPUT_TEAM_LEADER!$D$1)'
 
# -----------------------------
# Shared UI builders
# -----------------------------
def configure_sheet(ws, widths=None, freeze="A4"):
    ws.sheet_view.showGridLines = False
    ws.freeze_panes = freeze
    if widths:
        set_widths(ws, widths)
 
def add_sheet_header(ws, title):
    merge_write(ws, "A1:J1", dynamic_title(title), fill=fill_title, font=font_title, align=align_center)
    merge_write(ws, "A2:J2", '="Auto-populated from INPUT_TEAM_LEADER. Copy values into PowerPoint as needed."', fill=fill_note, font=font_note, align=align_left)
    set_row(ws, 1, 24)
    set_row(ws, 2, 22)
 
def add_section_band(ws, row, title):
    merge_write(ws, f"A{row}:J{row}", title, fill=fill_section, font=font_section, align=align_left)
    set_row(ws, row, 21)
 
def add_metric_table(ws, start_row, title, metrics):
    # metrics = [(label, formula, kind)]
    add_section_band(ws, start_row, title)
    hdr = start_row + 1
    merge_write(ws, f"A{hdr}:G{hdr}", "Metric", fill=fill_sub, font=font_sub, align=align_center)
    merge_write(ws, f"H{hdr}:J{hdr}", "Value", fill=fill_sub, font=font_sub, align=align_center)
    row = hdr + 1
    for label, formula, kind in metrics:
        merge_write(ws, f"A{row}:G{row}", label, fill=fill_label, font=font_body, align=align_left)
        numfmt = None
        if kind == "Currency":
            numfmt = '$#,##0;[Red]($#,##0);-'
        elif kind == "Percentage":
            numfmt = '0.0%'
        elif kind == "Number":
            numfmt = '#,##0;[Red](#,##0);-'
        merge_write(ws, f"H{row}:J{row}", formula, fill=fill_metric, font=font_metric, align=align_center, numfmt=numfmt)
        set_row(ws, row, 22)
        row += 1
    return row
 
def add_output_table(ws, start_row, title, headers, row_count, source_start_row, source_col_count, source_sheet="INPUT_TEAM_LEADER", widths=None, col_formats=None):
    add_section_band(ws, start_row, title)
    hdr = start_row + 1
    if widths:
        for idx, width in enumerate(widths, start=1):
            ws.column_dimensions[get_column_letter(idx)].width = max(ws.column_dimensions[get_column_letter(idx)].width or 0, width)
    for col_idx, header in enumerate(headers, start=1):
        c = ws.cell(hdr, col_idx, header)
        style(c, fill=fill_sub, font=font_sub, align=align_center)
    row = hdr + 1
    for r in range(row_count):
        for c_idx in range(1, source_col_count + 1):
            src = f"{get_column_letter(c_idx)}{source_start_row + r}"
            c = ws.cell(row, c_idx, f"='{source_sheet}'!{src}")
            fmt = None
            if col_formats and c_idx in col_formats:
                fmt = col_formats[c_idx]
            style(c, fill=fill_note, font=font_body, align=align_top_left if c_idx not in (3,4,5,6,7,8) else align_center, numfmt=fmt)
        set_row(ws, row, 30)
        row += 1
    return row
 
def add_input_row(ws, row, label, note="", response_span="E:G", label_span="B:D", note_span="H:J", response_type="Text"):
    merge_write(ws, f"{label_span.split(':')[0]}{row}:{label_span.split(':')[1]}{row}", label, fill=fill_label, font=font_body, align=align_left)
    merge_write(ws, f"{response_span.split(':')[0]}{row}:{response_span.split(':')[1]}{row}", "", fill=fill_input, font=font_input, align=align_left)
    merge_write(ws, f"{note_span.split(':')[0]}{row}:{note_span.split(':')[1]}{row}", note, fill=fill_note, font=font_note, align=align_left)
    set_row(ws, row, 24 if response_type != "Long text" else 34)
    return f"{response_span.split(':')[0]}{row}"
 
def add_input_detail_table(ws, start_row, title, headers, widths, rows, num_format_map=None):
    add_section_band(ws, start_row, title)
    hdr = start_row + 1
    for idx, (header, width) in enumerate(zip(headers, widths), start=1):
        c = ws.cell(hdr, idx, header)
        style(c, fill=fill_sub, font=font_sub, align=align_center)
        ws.column_dimensions[get_column_letter(idx)].width = max(ws.column_dimensions[get_column_letter(idx)].width or 0, width)
    first_data_row = hdr + 1
    for r in range(first_data_row, first_data_row + rows):
        for c_idx in range(1, len(headers) + 1):
            c = ws.cell(r, c_idx, "")
            fmt = None
            if num_format_map and c_idx in num_format_map:
                fmt = num_format_map[c_idx]
            style(c, fill=fill_input, font=font_input, align=align_top_left if c_idx not in (2,3,4,5,6,7,8,9) else align_left, numfmt=fmt)
        set_row(ws, r, 28)
    return first_data_row, first_data_row + rows - 1
 
