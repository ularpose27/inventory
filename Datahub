    }

    validate_financials(data)
    return data


def main():
    data = build_data()
    html_content = generate_report_html(data)
    output_path = write_html_file(html_content, OUTPUT_FILE)
    print(f"Generated {output_path.name} successfully.")


if __name__ == "__main__":
