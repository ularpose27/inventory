def add_sheet_title(ws, title):
    for col, width in zip("ABCDEFGHIJ", [18, 16, 16, 16, 16, 16, 18, 18, 18, 22]):
        ws.column_dimensions[col].width = width
    ws.sheet_view.showGridLines = False
    merge_write(ws, "A1:J1", f'=CONCAT("{title} | ",INPUT_TEAM_LEADER!$B$1," ",INPUT_TEAM_LEADER!$D$1)',
                fill=title_fill, font=title_font, align=center)
    merge_write(ws, "A2:J2", '="Auto-populated from INPUT_TEAM_LEADER. Copy values into PowerPoint as needed."',
                fill=note_fill, font=small_font, align=left)
    set_row(ws, 1, 24)
    set_row(ws, 2, 22)
    ws.freeze_panes = "A4"
 
 
def write_metric_table(ws, start_row, title, metrics):
    merge_write(ws, f"A{start_row}:J{start_row}", title, fill=section_fill, font=section_font, align=left)
    header_row = start_row + 1
    merge_write(ws, f"A{header_row}:G{header_row}", "Metric", fill=sub_fill, font=sub_font, align=center)
    merge_write(ws, f"H{header_row}:J{header_row}", "Value", fill=sub_fill, font=sub_font, align=center)
    row = header_row + 1
    for label, formula, kind in metrics:
        merge_write(ws, f"A{row}:G{row}", label, fill=label_fill, font=body_font, align=left)
        merge_write(ws, f"H{row}:J{row}", formula, fill=metric_fill, font=metric_font, align=center,
                    numfmt=("$#,##0" if kind == "Currency" else "0.0%" if kind == "Percentage" else None))
        set_row(ws, row, 22)
        row += 1
    return row
 
 
def link_detail_block(ws, start_row, title, headers, source_sheet, source_start_row, rows_count, num_formats=None, month_header_formulas=None):
    merge_write(ws, f"A{start_row}:J{start_row}", title, fill=section_fill, font=section_font, align=left)
    hr = start_row + 1
    col_letters = [get_column_letter(c) for c in range(1, len(headers)+1)]
    for idx, header in enumerate(headers, start=1):
        c = ws.cell(row=hr, column=idx, value=header)
        style_cell(c, fill=sub_fill, font=sub_font, align=center)
    for r in range(rows_count):
        for c_idx in range(1, len(headers)+1):
            dest = ws.cell(row=hr + 1 + r, column=c_idx)
            src_addr = f"{get_column_letter(c_idx)}{source_start_row + r}"
            dest.value = f"='INPUT_TEAM_LEADER'!{src_addr}"
            style_cell(dest, fill=note_fill if c_idx not in (len(headers),) else note_fill, font=body_font, align=top_left)
            if num_formats and c_idx in num_formats:
                dest.number_format = num_formats[c_idx]
        set_row(ws, hr + 1 + r, 26)
    return hr + 1 + rows_count
 
 
