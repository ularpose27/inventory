    widths = [34,14,14,14,16,28]
    for idx, (header, width) in enumerate(zip(headers, widths), start=1):
        c = ws.cell(hdr, idx, header)
        style(c, fill=fill_sub, font=font_sub, align=align_center)
        ws.column_dimensions[get_column_letter(idx)].width = width
    ws["B5"] = '=INPUT_TEAM_LEADER!F1'
    ws["C5"] = '=INPUT_TEAM_LEADER!H1'
    ws["D5"] = '=INPUT_TEAM_LEADER!J1'
    style(ws["B5"], fill=fill_sub, font=font_sub, align=align_center)
    style(ws["C5"], fill=fill_sub, font=font_sub, align=align_center)
    style(ws["D5"], fill=fill_sub, font=font_sub, align=align_center)
