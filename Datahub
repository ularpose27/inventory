    # slide 8 amount row on input sheet
    for c in ["D", "E", "F"]:
        ws[f"{c}{block['COI_MONTHLY_START']}"].number_format = '$#,##0'
    # third party cost column
    for r in range(block["TPP_TABLE_START"], block["TPP_TABLE_END"] + 1):
        ws[f"E{r}"].number_format = '$#,##0'
 
 
