random.seed(42)

def generate_financials():
    years = ["FY2021", "FY2022", "FY2023", "FY2024", "FY2025", "FY2026", "FY2027", "FY2028"]
    num_years = len(years)

    # Core assumptions
    rev_base = [1150.0, 1320.0, 1580.0, 1820.0, 1980.0, 2150.0, 2300.0, 2500.0]
    cogs_pct = [0.72, 0.73, 0.74, 0.74, 0.71, 0.70, 0.69, 0.68]
    opex_pct = [0.20, 0.19, 0.18, 0.19, 0.19, 0.18, 0.18, 0.17]
    ar_days  = [45, 48, 55, 62, 60, 58, 55, 52]
    inv_days = [110, 115, 125, 135, 130, 120, 115, 110]
    ap_days  = [50, 48, 45, 45, 50, 52, 55, 55]
    capex    = [30.0, 80.0, 120.0, 60.0, 40.0, 50.0, 60.0, 65.0]
    
    # Debt Schedule drivers (Initial balances)
    initial_cash = 45.0
    initial_ar = 140.0
    initial_inv = 250.0
    initial_ppne = 180.0
    initial_ap = 110.0
    initial_debt = 120.0
    initial_equity = initial_cash + initial_ar + initial_inv + initial_ppne - initial_ap - initial_debt

    fin = {
        "Years": years,
        "IS": {"Revenue": [], "COGS": [], "GrossProfit": [], "Opex": [], "EBITDA": [], "DA": [], "EBIT": [], "Interest": [], "EBT": [], "Tax": [], "NetIncome": []},
        "BS": {"Cash": [], "AR": [], "Inventory": [], "TotalCA": [], "PPNE": [], "TotalNCA": [], "TotalAssets": [],
               "AP": [], "ST_Debt": [], "TotalCL": [], "LT_Debt": [], "TotalNCL": [], "TotalLiabilities": [],
               "Equity": [], "TotalLiabilitiesEquity": []},
        "CF": {"NetIncome": [], "DA": [], "DeltaWC": [], "OCF": [], "Capex": [], "FCF": [], "NetBorrowing": [], "NetFinancing": [], "ChangeInCash": [], "EndingCash": []},
        "Metrics": {"GrossMargin": [], "EBITDAMargin": [], "NetMargin": [], "CurrentRatio": [], "CCC": [], "NetDebtEBITDA": [], "InterestCoverage": []}
    }

    cash = initial_cash
    ar = initial_ar
    inv = initial_inv
    ppne = initial_ppne
    ap = initial_ap
    debt = initial_debt
    equity = initial_equity

    for i in range(num_years):
        rev = rev_base[i]
        cogs = rev * cogs_pct[i]
        gp = rev - cogs
        opex = rev * opex_pct[i]
        ebitda = gp - opex
        
        # DA and PPNE
        da = ppne * 0.12
        new_ppne = ppne + capex[i] - da

        # Interest
        interest = debt * 0.085
        ebit = ebitda - da
        ebt = ebit - interest
        tax = max(0, ebt * 0.30)
        ni = ebt - tax

        # New Working Capital
        new_ar = rev * (ar_days[i] / 365)
        new_inv = cogs * (inv_days[i] / 365)
        new_ap = cogs * (ap_days[i] / 365)

        delta_ar = new_ar - ar
        delta_inv = new_inv - inv
        delta_ap = new_ap - ap
        delta_wc = -(delta_ar + delta_inv - delta_ap)

        # Cash Flow
        ocf = ni + da + delta_wc
        fcf = ocf - capex[i]

        # Debt Management
        # In FY26 we get the new facilities, we model a net borrowing spike, else normal amortization
        if years[i] == "FY2026":
            net_borrowing = 180.0 + 50.0  # Term loan + some revolver
        elif years[i] in ["FY2023", "FY2024"]:
            net_borrowing = 100.0  # Expansion debt
        else:
            net_borrowing = -30.0  # Amortization

        net_financing = net_borrowing
        change_in_cash = ocf - capex[i] + net_financing
        new_cash = cash + change_in_cash
        new_debt = debt + net_borrowing
        new_equity = equity + ni

        # Record IS
        fin["IS"]["Revenue"].append(rev)
        fin["IS"]["COGS"].append(cogs)
        fin["IS"]["GrossProfit"].append(gp)
        fin["IS"]["Opex"].append(opex)
        fin["IS"]["EBITDA"].append(ebitda)
        fin["IS"]["DA"].append(da)
        fin["IS"]["EBIT"].append(ebit)
        fin["IS"]["Interest"].append(interest)
        fin["IS"]["EBT"].append(ebt)
        fin["IS"]["Tax"].append(tax)
        fin["IS"]["NetIncome"].append(ni)

        # Record BS
        total_ca = new_cash + new_ar + new_inv
        total_nca = new_ppne
        total_assets = total_ca + total_nca
        
        st_debt = new_debt * 0.2
        lt_debt = new_debt * 0.8
        total_cl = new_ap + st_debt
        total_ncl = lt_debt
        total_liabs = total_cl + total_ncl
        total_liabs_equity = total_liabs + new_equity

        fin["BS"]["Cash"].append(new_cash)
        fin["BS"]["AR"].append(new_ar)
        fin["BS"]["Inventory"].append(new_inv)
        fin["BS"]["TotalCA"].append(total_ca)
        fin["BS"]["PPNE"].append(new_ppne)
        fin["BS"]["TotalNCA"].append(total_nca)
        fin["BS"]["TotalAssets"].append(total_assets)
        fin["BS"]["AP"].append(new_ap)
        fin["BS"]["ST_Debt"].append(st_debt)
        fin["BS"]["TotalCL"].append(total_cl)
        fin["BS"]["LT_Debt"].append(lt_debt)
        fin["BS"]["TotalNCL"].append(total_ncl)
        fin["BS"]["TotalLiabilities"].append(total_liabs)
        fin["BS"]["Equity"].append(new_equity)
        fin["BS"]["TotalLiabilitiesEquity"].append(total_liabs_equity)

        # Record CF
        fin["CF"]["NetIncome"].append(ni)
        fin["CF"]["DA"].append(da)
        fin["CF"]["DeltaWC"].append(delta_wc)
        fin["CF"]["OCF"].append(ocf)
        fin["CF"]["Capex"].append(capex[i])
        fin["CF"]["FCF"].append(fcf)
        fin["CF"]["NetBorrowing"].append(net_borrowing)
        fin["CF"]["NetFinancing"].append(net_financing)
        fin["CF"]["ChangeInCash"].append(change_in_cash)
        fin["CF"]["EndingCash"].append(new_cash)

        # Record Metrics
        fin["Metrics"]["GrossMargin"].append(gp / rev)
        fin["Metrics"]["EBITDAMargin"].append(ebitda / rev)
        fin["Metrics"]["NetMargin"].append(ni / rev)
        fin["Metrics"]["CurrentRatio"].append(total_ca / total_cl)
        fin["Metrics"]["CCC"].append(ar_days[i] + inv_days[i] - ap_days[i])
        net_debt = new_debt - new_cash
        fin["Metrics"]["NetDebtEBITDA"].append(net_debt / ebitda)
        fin["Metrics"]["InterestCoverage"].append(ebitda / interest)

        # Update for next year
        cash = new_cash
        ar = new_ar
        inv = new_inv
        ppne = new_ppne
        ap = new_ap
        debt = new_debt
        equity = new_equity

    return fin

def generate_working_capital_schedules(fin):
    # Distribute FY25 AR, INV, AP into aging buckets
    idx_25 = fin["Years"].index("FY2025")
    total_ar = fin["BS"]["AR"][idx_25]
    total_inv = fin["BS"]["Inventory"][idx_25]
    total_ap = fin["BS"]["AP"][idx_25]

    ar_aging = {
        "Current": total_ar * 0.50,
        "1-30 days": total_ar * 0.25,
        "31-60 days": total_ar * 0.12,
        "61-90 days": total_ar * 0.08,
        "Over 90 days": total_ar * 0.05
    }
    
    inv_aging = {
        "Current (0-30 days)": total_inv * 0.40,
        "31-90 days": total_inv * 0.30,
        "91-180 days": total_inv * 0.15,
        "181-365 days": total_inv * 0.10,
        "Over 365 days": total_inv * 0.05
    }

    ap_aging = {
        "Current": total_ap * 0.55,
        "1-30 days": total_ap * 0.30,
        "31-60 days": total_ap * 0.10,
        "61-90 days": total_ap * 0.04,
        "Over 90 days": total_ap * 0.01
    }
    return ar_aging, inv_aging, ap_aging

